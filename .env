# ================================
# ОСНОВНЫЕ НАСТРОЙКИ ПРИЛОЖЕНИЯ
# ================================
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ================================
# БАЗА ДАННЫХ
# ================================
# Строка подключения к PostgreSQL 
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jira-clone?schema=public"

# ================================
# ЗАГРУЗКА ФАЙЛОВ (CLOUDINARY)
# ================================
# Настройки для сервиса Cloudinary
#CLOUDINARY_CLOUD_NAME="demo"
#CLOUDINARY_API_KEY="123456789012345"
#CLOUDINARY_API_SECRET="abcdefghijklmnopqrstuvwxyz123"

# ================================
# КОНСТАНТЫ ПРИЛОЖЕНИЯ
# ================================
# Длина кода приглашения в рабочее пространство
INVITECODE_LENGTH=8

# Ограничения для загрузки изображений
MAX_FILE_SIZE=4194304 # 4MB
ACCEPTED_IMAGE_TYPES=["image/jpeg", "image/jpg", "image/png", "image/webp"]

# ================================
# ПРИМЕР НАСТРОЕК ДЛЯ МИГРАЦИИ ИЗ APPWRITE
# ================================
# Раскомментируйте и заполните эти настройки только если 
# требуется миграция данных из Appwrite в PostgreSQL

# NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# NEXT_PUBLIC_APPWRITE_PROJECT=ваш_project_id
# NEXT_PUBLIC_APPWRITE_DATABASE_ID=ваш_database_id
# NEXT_PUBLIC_APPWRITE_WORKSPACES_ID=ваш_workspaces_id
# NEXT_PUBLIC_APPWRITE_MEMBERS_ID=ваш_members_id
# NEXT_PUBLIC_APPWRITE_PROJECTS_ID=ваш_projects_id
# NEXT_PUBLIC_APPWRITE_TASKS_ID=ваш_tasks_id
# NEXT_PUBLIC_APPWRITE_IMAGES_BUCKET_ID=ваш_bucket_id
# NEXT_APPWRITE_KEY=ваш_секретный_ключ